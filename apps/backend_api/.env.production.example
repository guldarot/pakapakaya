NODE_ENV=production
PORT=4000
APP_VERSION=2026.05.01
APP_REVISION=git-sha-or-release-tag

CLIENT_ORIGIN=https://app.example.com
DATABASE_URL=postgresql://app_user:replace-me@db-host:5432/pakapakaya
PERSISTENCE_MODE=prisma
LOG_REQUESTS=true

STORAGE_DRIVER=gcs
STORAGE_LOCAL_DIR=./data/storage
STORAGE_PUBLIC_BASE_URL=https://api.example.com

GCS_BUCKET_NAME=pakapakaya-uploads
GCS_PUBLIC_BASE_URL=https://storage.googleapis.com/pakapakaya-uploads
S3_BUCKET_NAME=
S3_PUBLIC_BASE_URL=
